generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  isPremium        Boolean  @default(false)
  premiumUntil     DateTime?
  subscriptionPlan String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────
// STARS WALLET
// Every user gets one wallet
// ─────────────────────────────────────────
model StarsWallet {
  id              String   @id @default(uuid())
  userId          String   @unique
  balance         BigInt   @default(0)      // current spendable balance
  lockedBalance   BigInt   @default(0)      // locked in pending operations
  lifetimeEarned  BigInt   @default(0)      // total ever earned/purchased
  lifetimeSpent   BigInt   @default(0)      // total ever spent
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    StarsTransaction[]
  locks           StarsLock[]

  @@index([userId])
  @@map("stars_wallets")
}

// ─────────────────────────────────────────
// STARS LEDGER (Double Entry)
// Every movement of stars is recorded here
// Immutable — never update, only insert
// ─────────────────────────────────────────
model StarsLedgerEntry {
  id              String          @id @default(uuid())
  transactionId   String
  accountId       String          // userId or system account id
  accountType     LedgerAccountType
  entryType       LedgerEntryType // DEBIT or CREDIT
  amount          BigInt
  balanceAfter    BigInt          // snapshot of balance after this entry
  createdAt       DateTime        @default(now())

  transaction     StarsTransaction @relation("TransactionLedger", fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([accountId])
  @@index([createdAt])
  @@map("stars_ledger_entries")
}

enum LedgerAccountType {
  USER
  SYSTEM_PURCHASE_POOL    // stars bought with real money go here first
  SYSTEM_FEE_POOL         // platform fees collected here
  SYSTEM_CREATOR_EARNINGS // pending creator payouts
  SYSTEM_GIFT_ESCROW      // gifts waiting to be claimed
  SYSTEM_AUCTION_ESCROW   // bids locked during auctions
}

enum LedgerEntryType {
  DEBIT   // money going OUT of account
  CREDIT  // money coming IN to account
}

// ─────────────────────────────────────────
// STARS TRANSACTIONS
// High level record of what happened
// ─────────────────────────────────────────
model StarsTransaction {
  id              String               @id @default(uuid())
  walletId        String
  fromUserId      String?              // null = system/purchase
  toUserId        String?              // null = system/fee
  amount          BigInt
  type            StarsTransactionType
  status          StarsTransactionStatus @default(PENDING)
  referenceId     String?              // related entity id (giftId, reactionId etc)
  referenceType   String?              // "gift", "reaction", "tip", "purchase"
  description     String?
  metadata        Json?
  failureReason   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  completedAt     DateTime?

  wallet          StarsWallet          @relation(fields: [walletId], references: [id])
  ledgerEntries   StarsLedgerEntry[]   @relation("TransactionLedger")

  @@index([walletId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("stars_transactions")
}

enum StarsTransactionType {
  PURCHASE          // user bought stars with real money
  TRANSFER          // user to user transfer
  GIFT_SEND         // sending a gift
  GIFT_CLAIM        // claiming a received gift
  GIFT_REFUND       // gift rejected/refunded
  REACTION          // paid reaction on message
  TIP               // tip to creator/message
  CHANNEL_SUB       // channel subscription payment
  BOT_PAYMENT       // payment to a bot
  NFT_PURCHASE      // buying an NFT
  NFT_SALE          // receiving payment for NFT sale
  WITHDRAWAL        // converting stars to fiat/TON
  PLATFORM_FEE      // platform fee deduction
  PROMO_CREDIT      // promotional stars added by admin
  REFUND            // refund from platform
  ADJUSTMENT        // manual admin adjustment
}

enum StarsTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// ─────────────────────────────────────────
// STARS LOCKS
// Temporarily lock stars for pending ops
// e.g., locked during auction bidding
// ─────────────────────────────────────────
model StarsLock {
  id          String     @id @default(uuid())
  walletId    String
  userId      String
  amount      BigInt
  reason      String     // "auction_bid", "gift_pending", "withdrawal"
  referenceId String?    // auctionId, giftId, etc.
  expiresAt   DateTime   // auto-unlock after this
  isReleased  Boolean    @default(false)
  releasedAt  DateTime?
  createdAt   DateTime   @default(now())

  wallet      StarsWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([expiresAt])
  @@index([isReleased])
  @@map("stars_locks")
}

// ─────────────────────────────────────────
// STARS PURCHASE ORDERS
// Records of buying stars with real money
// ─────────────────────────────────────────
model StarsPurchaseOrder {
  id               String              @id @default(uuid())
  userId           String
  starsAmount      BigInt              // how many stars
  fiatAmount       Decimal             @db.Decimal(10, 2)
  currency         String              @default("USD")
  paymentProvider  String              // "apple_iap", "google_play", "ton", "stripe"
  providerOrderId  String?             // provider's order/transaction id
  receiptData      String?             @db.Text
  status           PurchaseOrderStatus @default(PENDING)
  tierId           String              // which price tier was selected
  bonusStars       BigInt              @default(0) // bonus stars from promotion
  failureReason    String?
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  completedAt      DateTime?

  @@index([userId])
  @@index([providerOrderId])
  @@index([status])
  @@map("stars_purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────
// STARS PRICE TIERS
// Different packages users can buy
// ─────────────────────────────────────────
model StarsPriceTier {
  id              String   @id @default(uuid())
  starsCount      BigInt   // how many stars in this package
  priceUsd        Decimal  @db.Decimal(10, 2)
  discountPercent Int      @default(0)
  bonusStars      BigInt   @default(0)   // extra stars on top
  isPopular       Boolean  @default(false)
  isBestValue     Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  appleProductId  String?  // App Store product ID
  googleProductId String?  // Play Store product ID
  createdAt       DateTime @default(now())

  @@map("stars_price_tiers")
}

// ─────────────────────────────────────────
// SYSTEM ACCOUNTS
// Virtual accounts for platform operations
// ─────────────────────────────────────────
model SystemAccount {
  id          String            @id @default(uuid())
  accountKey  SystemAccountKey  @unique
  balance     BigInt            @default(0)
  description String
  updatedAt   DateTime          @updatedAt

  @@map("system_accounts")
}

enum SystemAccountKey {
  PURCHASE_POOL
  FEE_POOL
  CREATOR_EARNINGS
  GIFT_ESCROW
  AUCTION_ESCROW
  PROMO_POOL
}

// ─────────────────────────────────────────
// GIFT ANIMATIONS CATALOG
// Different animation types for gifts
// ─────────────────────────────────────────
model GiftAnimation {
  id              String   @id @default(uuid())
  name            String   @unique
  displayName     String
  lottieUrl       String   // animation file URL
  thumbnailUrl    String
  category        String   // "classic", "premium", "seasonal", "rare"
  rarity          GiftRarity @default(COMMON)
  priceStars      BigInt   // base price in stars
  isAvailable     Boolean  @default(true)
  isLimited       Boolean  @default(false)
  availableUntil  DateTime?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  gifts           StarsGift[]

  @@map("gift_animations")
}

enum GiftRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

// ─────────────────────────────────────────
// STARS GIFTS
// Sending stars as a wrapped gift
// ─────────────────────────────────────────
model StarsGift {
  id              String      @id @default(uuid())
  fromUserId      String
  toUserId        String
  starsAmount     BigInt
  animationId     String?
  message         String?     @db.VarChar(255)
  status          GiftStatus  @default(PENDING)

  // NFT upgrade tracking
  isUpgradedToNft Boolean     @default(false)
  nftId           String?

  // Timing
  claimedAt       DateTime?
  rejectedAt      DateTime?
  expiresAt       DateTime    // unclaimed gifts expire after 30 days
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  animation       GiftAnimation? @relation(fields: [animationId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("stars_gifts")
}

enum GiftStatus {
  PENDING    // sent, not yet claimed
  CLAIMED    // recipient claimed it
  REJECTED   // recipient rejected it (stars returned)
  EXPIRED    // never claimed within expiry window
  REFUNDED   // sender got stars back
}

// ─────────────────────────────────────────
// PAID REACTIONS (Star Reactions)
// Sending stars WITH a reaction on a message
// ─────────────────────────────────────────
model PaidReaction {
  id              String   @id @default(uuid())
  messageId       String   // telegram message ID
  chatId          String   // telegram chat/channel ID
  userId          String   // who sent the reaction
  starsAmount     BigInt
  emoji           String   // reaction emoji
  isAnonymous     Boolean  @default(false)

  // Revenue tracking
  ownerUserId     String   // who receives the revenue (channel owner)
  platformFee     BigInt   // how much platform takes
  ownerEarned     BigInt   // how much owner gets

  createdAt       DateTime @default(now())

  @@index([messageId, chatId])
  @@index([userId])
  @@index([ownerUserId])
  @@index([chatId])
  @@map("paid_reactions")
}

// ─────────────────────────────────────────
// REACTION LEADERBOARD
// Top reactors per message/chat
// Updated asynchronously
// ─────────────────────────────────────────
model ReactionLeaderboard {
  id          String   @id @default(uuid())
  entityId    String   // messageId or chatId
  entityType  String   // "message" or "chat"
  userId      String
  totalStars  BigInt
  reactionCount Int    @default(1)
  lastReactedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityId, entityType, userId])
  @@index([entityId, entityType, totalStars])
  @@map("reaction_leaderboards")
}

// ─────────────────────────────────────────
// MESSAGE TIPS
// Tipping a specific message or creator
// ─────────────────────────────────────────
model MessageTip {
  id              String    @id @default(uuid())
  fromUserId      String
  toUserId        String    // message author / creator
  messageId       String?   // null = direct creator tip
  chatId          String?
  starsAmount     BigInt
  message         String?   @db.VarChar(200)
  isAnonymous     Boolean   @default(false)

  // Revenue split
  platformFee     BigInt
  creatorEarned   BigInt

  createdAt       DateTime  @default(now())

  @@index([fromUserId])
  @@index([toUserId])
  @@index([messageId])
  @@map("message_tips")
}

// ─────────────────────────────────────────
// REVENUE SETTLEMENTS
// Batch settlement of earned stars
// Creator revenue accumulates here
// before being moved to their wallet
// ─────────────────────────────────────────
model RevenueSettlement {
  id              String            @id @default(uuid())
  creatorId       String
  sourceType      String            // "reaction", "tip", "channel_sub", "story"
  sourceId        String            // referenceId of source
  grossAmount     BigInt
  platformFee     BigInt
  netAmount       BigInt
  status          SettlementStatus  @default(PENDING)
  settledAt       DateTime?
  createdAt       DateTime          @default(now())

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@map("revenue_settlements")
}

enum SettlementStatus {
  PENDING     // waiting for batch settlement
  PROCESSING  // currently being processed
  SETTLED     // credited to creator wallet
  FAILED      // settlement failed
}
